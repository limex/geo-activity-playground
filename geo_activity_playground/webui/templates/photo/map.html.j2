{% extends "page.html.j2" %}

{% block container %}
<h1>{{ _('Photo Map') }}</h1>

{% if external_map_url %}
<div class="d-flex justify-content-end mb-2">
    <a id="external-map-link" href="#" target="_blank" class="btn btn-sm btn-outline-secondary">{{ _('External Map') }}</a>
</div>
{% endif %}

<div id="photo-map" style="height: 800px;" class="mb-3"></div>
<script>
    var map = L.map('photo-map', {
        fullscreenControl: true
    });
    L.control.locate({ position: 'topleft' }).addTo(map);
    L.tileLayer('/tile/{{ map_tile_style_standard }}/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '{{ map_tile_attribution|safe }}'
    }).addTo(map);

    {% if external_map_url %}
    const externalMapBaseUrl = {{ external_map_url | tojson }};

    function updateExternalMapLink() {
        const center = map.getCenter();
        const zoom = map.getZoom();
        const lat = center.lat.toFixed(5);
        const lon = center.lng.toFixed(5);
        const link = document.getElementById('external-map-link');
        if (!link) return;
        link.href = externalMapBaseUrl
            .replace('{zoom}', zoom)
            .replace('{lat}', lat)
            .replace('{lon}', lon);
    }

    map.on('moveend zoomend', updateExternalMapLink);
    {% endif %}

    fetch("{{ url_for('photo.map_for_all') }}")
        .then(function (response) {
            return response.json();
        })
        .then(function (data) {
            let layer = L.geoJSON(data, {
                pointToLayer: function (feature, latlng) {
                    return L.marker(latlng, {
                        icon: new L.Icon({
                            iconSize: [32, 32],
                            iconAnchor: [16, 16],
                            popupAnchor: [16, 0],
                            iconUrl: feature.properties.url_marker,
                        })
                    });
                },
                onEachFeature: function (feature, layer) {
                    const activityLink = feature.properties.url_activity
                        ? `<a href="${feature.properties.url_activity}" target="_blank" style="position:absolute;top:4px;left:4px;background:rgba(255,255,255,0.85);padding:4px 7px;border-radius:3px;font-size:12px;font-weight:bold;text-decoration:none;color:#333;line-height:normal;">${feature.properties.activity_id}</a>`
                        : '';
                    layer.bindPopup(
                        `<div style="position:relative;line-height:0;">${activityLink}<a href="${feature.properties.url_full}" target="_blank"><img src="${feature.properties.url_popup}" style="display:block;max-width:512px;" /></a></div>`,
                        { maxWidth: 540 }
                    );
                    layer.on('popupopen', function () {
                        const img = layer.getPopup().getElement().querySelector('img');
                        if (img && !img.complete) {
                            img.addEventListener('load', function () {
                                layer.getPopup().update();
                            });
                        }
                    });
                }
            })

            let group = L.markerClusterGroup()
            group.addLayer(layer)

            group.addTo(map);
            {% if initial_view %}
            map.setView([{{ initial_view.lat }}, {{ initial_view.lon }}], {{ initial_view.zoom }});
            {% else %}
            map.fitBounds(group.getBounds());
            {% endif %}
            {% if external_map_url %}updateExternalMapLink();{% endif %}
        });
</script>

{% endblock %}