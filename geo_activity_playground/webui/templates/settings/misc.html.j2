{% extends "settings/base.html.j2" %}

{% block breadcrumbs %}
<li class="breadcrumb-item active" aria-current="page">{{ _('Misc.') }}</li>
{% endblock %}

{% block settings_content %}
<h1 class="mb-3">{{ _('Misc.') }}</h1>

<form method="POST">
    <h5 class="mt-4">{{ _('Photo Import') }}</h5>
    <div class="row mb-3">
        <div class="col-lg-4">
            <label for="photo_grace_period_minutes" class="form-label">{{ _('Grace period (minutes)') }}</label>
            <input type="number" class="form-control" id="photo_grace_period_minutes"
                name="photo_grace_period_minutes" value="{{ photo_grace_period_minutes }}" min="0" />
            <div class="form-text">{{ _('Photos taken this many minutes before or after an activity will still be matched to it.') }}</div>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-lg-4">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="photo_import_standalone"
                    name="photo_import_standalone" {% if photo_import_standalone %}checked{% endif %} />
                <label class="form-check-label" for="photo_import_standalone">{{ _('Import Standalone Photos') }}</label>
            </div>
            <div class="form-text">{{ _('When off, only photos taken during an activity (within the grace period) are imported — photos outside any activity window are skipped and stay in the upload folder. This lets you review which photos have no matching activity before deciding what to do with them. Enable this only if you want those photos on the map regardless, linked to their GPS position alone.') }}</div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">{{ _('Save') }}</button>
</form>
{% endblock %}
