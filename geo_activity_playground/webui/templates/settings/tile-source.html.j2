{% extends "settings/base.html.j2" %}

{% block breadcrumbs %}
<li class="breadcrumb-item active" aria-current="page">{{ _('Map Tile Source') }}</li>
{% endblock %}

{% block settings_content %}
<h1 class="mb-3">{{ _('Tile Source') }}</h1>

<p>{{ _('You can change the tile source to be whatever you like. Be aware that different sources have different licensing constraints. It is on you to make sure that you are allowed to use the tiles from the source that you enter. See') }} <a
        href="https://wiki.openstreetmap.org/wiki/Raster_tile_providers" target="_blank">{{ _('this list of raster tile providers') }}</a> {{ _('for inspiration.') }}</p>


<form action="" method="POST" class="mb-3">
    <div class="mb-3">
        <label for="map_tile_url" class="form-label">{{ _('Map tile URL') }}</label>
        <input type="text" class="form-control" id="map_tile_url" name="map_tile_url" value="{{ map_tile_url }}" />
    </div>
    <div class="mb-3">
        <label for="map_tile_attribution" class="form-label">{{ _('Map tile attribution') }}</label>
        <input type="text" class="form-control" id="map_tile_attribution" name="map_tile_attribution"
            value="{{ map_tile_attribution|e }}" />
    </div>

    <h5 class="mt-4">{{ _('Map Styles') }}</h5>
    <p class="text-muted">{{ _('Choose the color transform applied to tiles for each map type. "Color" means no transform (tiles as-is). Transforms are applied server-side.') }}</p>
    {% set style_options = [('color', _('Color')), ('pastel', _('Pastel')), ('grayscale', _('Grayscale')), ('inverse_grayscale', _('Inverse Grayscale')), ('blank', _('Blank'))] %}

    <div class="row mb-3">
        <div class="col-lg-4">
            <label for="map_tile_style_standard" class="form-label">{{ _('Standard maps') }}</label>
            <select class="form-select" id="map_tile_style_standard" name="map_tile_style_standard">
                {% for value, label in style_options %}
                <option value="{{ value }}" {% if map_tile_style_standard == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            <div class="form-text">{{ _('Used for: home, photo map, search, segments, hall of fame.') }}</div>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-lg-4">
            <label for="map_tile_style_activity" class="form-label">{{ _('Activity map') }}</label>
            <select class="form-select" id="map_tile_style_activity" name="map_tile_style_activity">
                {% for value, label in style_options %}
                <option value="{{ value }}" {% if map_tile_style_activity == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            <div class="form-text">{{ _('Used for: activity detail page, trim map.') }}</div>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-lg-4">
            <label for="map_tile_style_track" class="form-label">{{ _('Track overlay maps') }}</label>
            <select class="form-select" id="map_tile_style_track" name="map_tile_style_track">
                {% for value, label in style_options %}
                <option value="{{ value }}" {% if map_tile_style_track == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            <div class="form-text">{{ _('Used for: activity lines, names, and day view — maps where the GPS track is the focus.') }}</div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">{{ _('Save') }}</button>
</form>

<h2>{{ _('Test image') }}</h2>

<p>{{ _('This is a tile using your current tile source:') }}</p>

<p><img src="{{ test_url }}"></p>
{% endblock %}
