{% extends "page.html.j2" %}

{% block container %}

<h1 class="row mb-3">{{ _('Activities Overview & Search') }}</h1>

<div class="mb-3">
    {% include "search_form.html.j2" %}
</div>

<div class="d-flex flex-wrap align-items-center gap-3 mb-3">
    <a href="{{ url_for('search.map_view') }}?{{ base_query_str }}">{{ _('Map view') }}</a>
    <span class="text-body-secondary">|</span>
    <span class="small"><span class="text-body-secondary">{{ _('Activities') }}:</span> <strong>{{ total }}</strong></span>
    <span class="small"><span class="text-body-secondary">{{ _('Distance') }}:</span> <strong>{{ '%.1f'|format(total_distance_km) }} km</strong></span>
    <span class="small"><span class="text-body-secondary">{{ _('Elevation') }}:</span> <strong>{{ '%.0f'|format(total_elevation_gain_m) }} m</strong></span>
    <span class="small"><span class="text-body-secondary">{{ _('Time') }}:</span> <strong>{{ total_elapsed_time|td }}</strong></span>
</div>

<table class="table table-sort table-arrows">
    <thead>
        <tr>
            <th>{{ _('Name') }}</th>
            <th>{{ _('Date') }}</th>
            <th class="numeric-sort">{{ _('Distance') }}</th>
            <th>{{ _('Elapsed time') }}</th>
            <th>{{ _('Speed / km/h') }}</th>
            <th>{{ _('Equipment') }}</th>
            <th>{{ _('Kind') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for index, activity in activities %}
        <tr>
            <td><a href="{{ url_for('activity.show', id=activity['id']) }}">{{ activity['name'] }}</a></td>
            <td>
                {% if activity['start_local'] is defined %}
                {{ activity['start_local']|dt }} {{ activity.iana_timezone }}
                {% endif %}
            </td>
            <td>{{ '%.1f' % activity["distance_km"] }} km</td>
            <td>{{ activity.elapsed_time|td }}</td>
            <td>
                {% if not activity.average_speed_moving_kmh|isna %}
                {{ activity.average_speed_moving_kmh|round(1) }}
                {% endif %}
            </td>
            <td>{{ activity["equipment"] }}</td>
            <td>{{ activity['kind'] }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}